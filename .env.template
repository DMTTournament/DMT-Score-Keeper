# HLL Tank Overwatch Discord Bot Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# REQUIRED SETTINGS - Bot will not start without these
# =============================================================================

# Discord Bot Token - Get from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# HLL Game Server RCON credentials (direct RCON V2 connection)
RCON_HOST=216.245.210.196
RCON_PORT=7779
RCON_PASSWORD=cb01n6qb

# =============================================================================
# RCON SETTINGS
# =============================================================================

# RCON command timeout in seconds
RCON_TIMEOUT=30

# Auto-switch teams when point captures are detected (true/false)
RCON_AUTO_SWITCH=true

# =============================================================================
# BOT BEHAVIOR SETTINGS
# =============================================================================

# How often to update the Discord embed (seconds)
UPDATE_INTERVAL=15

# Discord role name required to control the bot
ADMIN_ROLE_NAME=admin

# Bot name shown in game messages
BOT_NAME=HLLTankBot

# Author name shown in embed footer
BOT_AUTHOR=YourCommunityName

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# Discord channel ID for logging match results (0 to disable)
LOG_CHANNEL_ID=0

# =============================================================================
# DEVIL DAVE INTEGRATION (optional - posts match results to Devil Dave event stats)
# =============================================================================

# Devil Dave stats site URL
DEVIL_DAVE_URL=https://www.the504thdevils.us

# API key (same as EVENT_STATS_API_KEY set in Devil Dave's environment)
DEVIL_DAVE_API_KEY=your_event_stats_api_key_here

# Optional: leave blank to use the currently active event, or set a specific event ID
DEVIL_DAVE_EVENT_ID=
